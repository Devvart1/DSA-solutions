vector<long long> printFirstNegativeInteger(long long int a[],
                                             long long int n, long long int k) {
                                                vector<long long> ans;
                                                 list<int> v;
                                                 long long int i,j,x;
                                                 i=0;
                                                j=0;
                                                 while(j<n)
                                                 {
                                                     
                                                          if(a[j]<0)
                                                         v.push_back(a[j]);
                                                     if((j-i+1)<k)
                                                     j++;
                                                         else if((j-i+1)==k)
                                                     {
                                                         if(v.size()==0)
                                                         ans.push_back(0);
                                                         else{
                                                             
                                                         ans.push_back(v.front());
                                                         }
                                                         
                                                          if(a[i]==v.front())
                                                         v.pop_front();
                                                         
                                                         
                                                        
                                                         
                                                         i++;
                                                         j++;
                                                         
                                                     }
                                                     
                                                 }
                                                 return ans;
 }
