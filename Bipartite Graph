 // } Driver Code Ends
class Solution {
public:

bool check(int src,vector<int> adj[],int color[])
{
    queue<int> pq;
    pq.push(src);
    color[src]=1;
    while(!pq.empty())
    {
        int node =pq.front();
        pq.pop();
        
        for(auto it:adj[node])
        {
            if(color[it]==-1)
            {
                color[it]=1-color[node];
                pq.push(it);
                
            }
            else if(color[it]==color[node])
            return false;
            
        }
    }
        return true;
    }
    

	bool isBipartite(int V, vector<int>adj[]){
	  int color[V];
	  memset(color,-1,sizeof color);
	  for(int i =0;i<V;++i)
	  {
	      if(color[i]==-1)
	      {
	          if(!check(i,adj,color))
	          {
	              return false;
	              
	          }
	      }
	  }
	  return true;
	  
	}

};

