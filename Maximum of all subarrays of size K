class Solution {
  public:
 void heapify(vector<int> &a,int n, int i)  
    {
      int lar=i;
      int l=i*2+1;
      int r=i*2+2;
      
      if(l<n&&a[l]>a[lar])
      lar=l;
      if(r<n&&a[r]>a[lar])
      lar=r;
      if(lar!=i)
      {
          swap(a[lar],a[i]);
          heapify(a,n,lar);
      }
    }
  int create(vector<int> a,int n)
  {
      for(int i=(n-2)/2;i>=0;--i)
      {
          
          heapify(a,n,i);
      }
      return a[0];
  }
    vector<int> max_of_subarrays(vector<int> a, int n, int k) {
      vector<int> ans;
       vector<int>::iterator it;
      for(int i=0;i<=n-k;++i)
      {
           ans.push_back(create(a,k));
      it = a.begin();
    a.erase(it);
      }
     
      
       return ans;
    }
};

